<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.rastuarent.LoginController"
      alignment="CENTER"
      spacing="0"
      style="-fx-background-color: #ffffff;">

    <VBox alignment="CENTER" prefHeight="180" spacing="10"
          style="-fx-background-color: #f1f8e9; -fx-padding: 20;">
        <ImageView fitHeight="70" preserveRatio="true">
            <Image url="@images/logoo.jpg"/>
        </ImageView>
        <Label text="User Authentication" style="-fx-text-fill: #2e7d32; -fx-font-weight: bold; -fx-letter-spacing: 1px;"/>
    </VBox>

    <VBox spacing="25" maxWidth="400" alignment="CENTER" style="-fx-padding: 40; -fx-background-color: white;">

        <VBox spacing="8">
            <Label text="Username" style="-fx-text-fill: #495057; -fx-font-weight: bold;"/>
            <TextField fx:id="txtUsername" promptText="Enter your ID"
                       style="-fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 12;"/>
        </VBox>

        <VBox spacing="8">
            <Label text="Password" style="-fx-text-fill: #495057; -fx-font-weight: bold;"/>
            <PasswordField fx:id="txtPassword" promptText="••••••••"
                           style="-fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 12;"/>
        </VBox>

        <VBox spacing="15" alignment="CENTER">
            <Button text="Login to Dashboard" onAction="#handleLogin" prefWidth="320"
                    style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 14; -fx-cursor: hand;"/>

            <Hyperlink text="New here? Create an account" onAction="#goToSignup"
                       style="-fx-text-fill: #e67e22; -fx-underline: false; -fx-font-size: 13px;"/>
        </VBox>

        <Label fx:id="lblMessage" text="" style="-fx-text-fill: #d63031;"/>
    </VBox>

</VBox>